---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import countryCodes from '../utils/country-codes.json';

const timeSlots = [
  '11:00 AM – 12:00 PM',
  '12:00 PM – 1:00 PM',
  '1:00 PM – 2:00 PM',
  '2:00 PM – 3:00 PM',
  '3:00 PM – 4:00 PM',
  '4:00 PM – 5:00 PM',
  '5:00 PM – 6:00 PM',
];

const teamSizes = [
  '1–10 employees',
  '11–50 employees',
  '51–200 employees',
  '201–500 employees',
  '500+ employees',
];
---

<Layout
  title="Book a Demo – QualifyMe AI Hiring Assistant"
  description="See QualifyMe in action. Book a personalized 30-minute demo to explore AI screening, cognitive simulations, and how we cut hiring time by up to 70%."
  keywords="book demo, QualifyMe demo, AI hiring demo, recruitment software demo, hiring automation demo"
  ogImage="/images/qualifyme-portal.avif"
>
  <main class="mb-40">

    {/* Hero */}
    <section class="pt-40 pb-16">
      <Container>
        <div class="text-center max-w-3xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 text-sm font-medium mb-6">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            30-Minute Live Demo
          </span>
          <h1 class="text-4xl font-bold text-gray-900 dark:text-white md:text-5xl lg:text-6xl mb-6 leading-tight">
            See QualifyMe<br/>in Action
          </h1>
          <p class="text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
            Get a personalised walkthrough of AI screening, cognitive simulations, and how QualifyMe cuts your time-to-hire by up to 70%.
          </p>
        </div>
      </Container>
    </section>

    {/* Main content */}
    <section class="py-8">
      <Container>
        <div class="flex flex-col lg:flex-row gap-12 items-start">

          {/* Left – what to expect */}
          <div class="w-full lg:w-5/12 lg:sticky lg:top-28">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">What we'll cover</h2>

            <div class="space-y-6 mb-10">
              {[
                {
                  icon: `<path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,
                  title: 'AI Candidate Screening',
                  desc: 'Watch how QualifyMe automatically evaluates CVs and ranks candidates against your job requirements in seconds.',
                },
                {
                  icon: `<path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
                  title: 'Cognitive Simulations',
                  desc: 'See role-specific simulations that reveal real-world problem-solving ability—beyond what any CV can show.',
                },
                {
                  icon: `<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />`,
                  title: 'Analytics & Insights',
                  desc: 'Explore the scoring dashboards and team-level reports that help you make data-backed hiring decisions.',
                },
                {
                  icon: `<path d="M13 10V3L4 14h7v7l9-11h-7z" />`,
                  title: 'Setup & Onboarding',
                  desc: 'Learn how most teams go live in under a day—no IT required—and start seeing results within the first week.',
                },
              ].map((item) => (
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center">
                    <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={item.icon} />
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 dark:text-white mb-1">{item.title}</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>

            {/* Social proof */}
            <div class="bg-indigo-50 dark:bg-indigo-900/20 rounded-2xl p-6 border border-indigo-100 dark:border-indigo-800/40">
              <div class="flex items-center gap-1 mb-3">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <blockquote class="text-sm text-gray-700 dark:text-gray-300 italic mb-3">
                "We cut our time-to-hire by 65% in the first month. The demo showed us exactly what to expect—no surprises."
              </blockquote>
              <p class="text-xs font-medium text-gray-500 dark:text-gray-400">— Head of Talent, Series B Fintech</p>
            </div>
          </div>

          {/* Right – booking form */}
          <div class="w-full lg:w-7/12">
            <div class="bg-white dark:bg-gray-800 rounded-3xl shadow-xl p-8 border border-gray-100 dark:border-gray-700">
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Book your slot</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-8">Available Monday – Friday, 11 AM – 6 PM IST</p>

              <form id="bookDemoForm" class="space-y-6" novalidate>

                {/* Name + Email */}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Full Name <span class="text-red-500">*</span></label>
                    <input type="text" id="name" name="name" required autocomplete="name"
                      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Work Email <span class="text-red-500">*</span></label>
                    <input type="email" id="email" name="email" required autocomplete="email"
                      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                  </div>
                </div>

                {/* Company + Role */}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div>
                    <label for="company" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Company Name <span class="text-red-500">*</span></label>
                    <input type="text" id="company" name="company" required autocomplete="organization"
                      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                  </div>
                  <div>
                    <label for="role" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Your Role</label>
                    <input type="text" id="role" name="role" autocomplete="organization-title" placeholder="e.g. Head of Talent"
                      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                  </div>
                </div>

                {/* Phone */}
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                  <div class="sm:col-span-1 relative">
                    <label for="countryCodeInput" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Country Code</label>
                    <input
                      type="text"
                      id="countryCodeInput"
                      placeholder="Search…"
                      autocomplete="off"
                      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                    />
                    <input type="hidden" id="countryCode" name="countryCode" />
                    <div id="countryDropdown" class="hidden absolute z-50 w-full mt-1 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-xl shadow-lg max-h-56 overflow-y-auto"></div>
                  </div>
                  <div class="sm:col-span-2">
                    <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Phone Number</label>
                    <input type="tel" id="phone" name="phone" placeholder="Enter phone number"
                      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                  </div>
                </div>

                {/* Team size */}
                <div>
                  <label for="teamSize" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Team Size</label>
                  <select id="teamSize" name="teamSize"
                    class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition appearance-none">
                    <option value="">Select team size…</option>
                    {teamSizes.map((s) => <option value={s}>{s}</option>)}
                  </select>
                </div>

                {/* Date picker */}
                <div>
                  <label for="date" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Preferred Date <span class="text-red-500">*</span></label>
                  <input type="date" id="date" name="date" required
                    class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                  <p id="dateError" class="hidden mt-1 text-xs text-red-500">Please select a weekday (Monday – Friday).</p>
                </div>

                {/* Time slots */}
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Preferred Time <span class="text-red-500">*</span></label>
                  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2.5" id="timeSlotGrid">
                    {timeSlots.map((slot) => (
                      <label class="time-slot-label relative cursor-pointer">
                        <input type="radio" name="timeSlot" value={slot} class="sr-only peer" required />
                        <div class="px-3 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 text-center text-sm font-medium text-gray-700 dark:text-gray-300 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 dark:peer-checked:bg-indigo-900/30 peer-checked:text-indigo-700 dark:peer-checked:text-indigo-300 hover:border-indigo-300 dark:hover:border-indigo-600 transition-all select-none">
                          {slot}
                        </div>
                      </label>
                    ))}
                  </div>
                </div>

                {/* Optional message */}
                <div>
                  <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Anything you'd like us to focus on? <span class="text-gray-400 font-normal">(optional)</span></label>
                  <textarea id="message" name="message" rows="3" placeholder="e.g. We're hiring for 5 engineering roles and need to evaluate problem-solving skills…"
                    class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition resize-none"></textarea>
                </div>

                <button type="submit" id="submitBtn"
                  class="w-full flex items-center justify-center gap-2 h-12 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-sm transition-colors shadow-sm shadow-indigo-500/30 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Book My Demo
                </button>
              </form>

              <div id="formSuccess" class="hidden mt-6 p-5 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-2xl">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <div>
                    <p class="font-semibold text-green-800 dark:text-green-200 mb-1">Demo request received!</p>
                    <p class="text-sm text-green-700 dark:text-green-300">We'll confirm your slot and send a calendar invite to your email within a few hours.</p>
                  </div>
                </div>
              </div>

              <div id="formError" class="hidden mt-6 p-5 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-2xl">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-red-600 dark:text-red-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <p class="text-sm text-red-800 dark:text-red-200">Something went wrong. Please try again or email us at <a href="mailto:support@qualifyme.ai" class="underline">support@qualifyme.ai</a>.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </section>
  </main>
</Layout>

<script define:vars={{ countryCodes }}>
  // ── Country code typeahead ──
  const countryCodeInput = document.getElementById('countryCodeInput');
  const countryCodeHidden = document.getElementById('countryCode');
  const countryDropdown = document.getElementById('countryDropdown');

  if (countryCodeInput && countryCodeHidden && countryDropdown) {
    let selectedIndex = -1;

    function showDropdown(query) {
      const filtered = countryCodes.filter((c) =>
        c.name.toLowerCase().includes(query.toLowerCase()) || c.dial_code.includes(query)
      );
      if (!filtered.length) { countryDropdown.classList.add('hidden'); return; }

      countryDropdown.innerHTML = filtered.map((c, i) => `
        <div class="country-option px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-600 cursor-pointer text-sm ${i === selectedIndex ? 'bg-gray-100 dark:bg-gray-600' : ''}"
             data-dial="${c.dial_code}" data-name="${c.name}">
          <span class="font-medium">${c.dial_code}</span>
          <span class="text-gray-500 dark:text-gray-400 ml-2">${c.name}</span>
        </div>`).join('');
      countryDropdown.classList.remove('hidden');
      selectedIndex = -1;
    }

    function selectCountry(el) {
      const dial = el.getAttribute('data-dial');
      const name = el.getAttribute('data-name');
      if (dial && name) {
        countryCodeInput.value = `${dial} (${name})`;
        countryCodeHidden.value = dial;
        countryDropdown.classList.add('hidden');
        selectedIndex = -1;
      }
    }

    function updateSelection() {
      countryDropdown.querySelectorAll('.country-option').forEach((opt, i) => {
        opt.classList.toggle('bg-gray-100', i === selectedIndex);
        opt.classList.toggle('dark:bg-gray-600', i === selectedIndex);
      });
    }

    countryCodeInput.addEventListener('input', (e) => {
      e.target.value.length > 0 ? showDropdown(e.target.value) : countryDropdown.classList.add('hidden');
    });

    countryCodeInput.addEventListener('keydown', (e) => {
      const opts = countryDropdown.querySelectorAll('.country-option');
      if (e.key === 'ArrowDown') { e.preventDefault(); selectedIndex = Math.min(selectedIndex + 1, opts.length - 1); updateSelection(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); selectedIndex = Math.max(selectedIndex - 1, -1); updateSelection(); }
      else if (e.key === 'Enter') { e.preventDefault(); if (selectedIndex >= 0 && opts[selectedIndex]) selectCountry(opts[selectedIndex]); }
      else if (e.key === 'Escape') { countryDropdown.classList.add('hidden'); selectedIndex = -1; }
    });

    countryDropdown.addEventListener('click', (e) => {
      const opt = e.target.closest('.country-option');
      if (opt) selectCountry(opt);
    });

    document.addEventListener('click', (e) => {
      if (!countryCodeInput.contains(e.target) && !countryDropdown.contains(e.target)) {
        countryDropdown.classList.add('hidden'); selectedIndex = -1;
      }
    });
  }

  // ── Restrict date input to weekdays only ──
  const dateInput = document.getElementById('date');
  const dateError = document.getElementById('dateError');

  if (dateInput) {
    // Set min to today
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    dateInput.min = `${yyyy}-${mm}-${dd}`;

    dateInput.addEventListener('change', () => {
      const d = new Date(dateInput.value + 'T00:00:00');
      const day = d.getDay(); // 0=Sun, 6=Sat
      if (day === 0 || day === 6) {
        dateInput.setCustomValidity('Please select a weekday.');
        dateError.classList.remove('hidden');
      } else {
        dateInput.setCustomValidity('');
        dateError.classList.add('hidden');
      }
    });
  }

  // ── Form submission ──
  document.getElementById('bookDemoForm')?.addEventListener('submit', async function (e) {
    e.preventDefault();

    // Validate weekday
    if (dateInput) {
      const d = new Date(dateInput.value + 'T00:00:00');
      const day = d.getDay();
      if (day === 0 || day === 6) {
        dateError.classList.remove('hidden');
        dateInput.focus();
        return;
      }
    }

    const submitBtn = document.getElementById('submitBtn');
    const successDiv = document.getElementById('formSuccess');
    const errorDiv = document.getElementById('formError');

    successDiv.classList.add('hidden');
    errorDiv.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    const fd = new FormData(this);
    const countryCode = fd.get('countryCode');
    const phone = fd.get('phone');
    const fullPhone = countryCode && phone ? `${countryCode} ${phone}` : (phone || '');

    try {
      const res = await fetch('/api/book-demo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fd.get('name'),
          email: fd.get('email'),
          company: fd.get('company'),
          role: fd.get('role'),
          teamSize: fd.get('teamSize'),
          phone: fullPhone,
          date: fd.get('date'),
          timeSlot: fd.get('timeSlot'),
          message: fd.get('message'),
        }),
      });

      if (res.ok) {
        successDiv.classList.remove('hidden');
        this.reset();
        successDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        errorDiv.classList.remove('hidden');
      }
    } catch {
      errorDiv.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/></svg> Book My Demo`;
    }
  });
</script>
