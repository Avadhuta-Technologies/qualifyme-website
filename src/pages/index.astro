<script>
  // Scroll-reveal with IntersectionObserver
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

  // ── Case study carousel ──────────────────────────────────────────────────
  const track    = document.getElementById("cs-track") as HTMLElement;
  const dots     = document.querySelectorAll<HTMLButtonElement>(".cs-dot");
  const prevBtn  = document.getElementById("cs-prev") as HTMLButtonElement;
  const nextBtn  = document.getElementById("cs-next") as HTMLButtonElement;
  const counter  = document.getElementById("cs-counter") as HTMLElement;
  const total    = dots.length;
  let current    = 0;

  const accentActive: Record<number, string> = {
    0: "bg-indigo-600",
    1: "bg-violet-600",
    2: "bg-cyan-600",
    3: "bg-emerald-600",
  };
  const accentProgress: Record<number, string> = {
    0: "bg-indigo-600",
    1: "bg-violet-600",
    2: "bg-cyan-600",
    3: "bg-emerald-600",
  };

  // Progress bar animation
  let progressRaf: number | null = null;
  let progressStart: number | null = null;

  function startProgress() {
    stopProgress();
    const bar = document.getElementById("cs-progress");
    if (!bar) return;
    bar.style.transition = "none";
    bar.style.width = "0%";
    // Tiny delay so the reset paint flushes before animating
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        bar.style.transition = `width ${AUTOPLAY_MS}ms linear`;
        bar.style.width = "100%";
      });
    });
  }
  function stopProgress() {
    const bar = document.getElementById("cs-progress");
    if (!bar) return;
    bar.style.transition = "none";
    bar.style.width = "0%";
  }

  function goTo(idx: number) {
    current = (idx + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    track.style.transition = "transform 0.48s cubic-bezier(0.4,0,0.2,1)";

    dots.forEach((d, i) => {
      const active = i === current;
      // Remove old progress bar span from every dot
      const oldBar = d.querySelector("#cs-progress");
      if (oldBar) oldBar.remove();

      if (active) {
        d.className = `cs-dot relative rounded-full overflow-hidden transition-all duration-300 w-16 h-2 bg-gray-200 dark:bg-gray-700`;
        const bar = document.createElement("span");
        bar.id = "cs-progress";
        bar.className = `absolute inset-y-0 left-0 rounded-full ${accentProgress[current] ?? "bg-indigo-600"}`;
        bar.style.width = "0%";
        d.appendChild(bar);
      } else {
        d.className = `cs-dot rounded-full transition-all duration-300 w-2 h-2 bg-gray-300 dark:bg-gray-600 hover:bg-gray-400`;
      }
    });

    counter.textContent = `${current + 1} / ${total}`;
    prevBtn.disabled = false;
    nextBtn.disabled = false;
  }

  // ── Autoscroll ──────────────────────────────────────────────────────────
  const AUTOPLAY_MS = 4500;
  let autoTimer: ReturnType<typeof setInterval> | null = null;

  function startAuto() {
    stopAuto();
    startProgress();
    autoTimer = setInterval(() => { goTo(current + 1); startProgress(); }, AUTOPLAY_MS);
  }
  function stopAuto() {
    if (autoTimer !== null) { clearInterval(autoTimer); autoTimer = null; }
    stopProgress();
  }
  // Pause on any user interaction, resume 6 s after they stop
  function onUserInteract() {
    stopAuto();
    clearTimeout((onUserInteract as any)._resume);
    (onUserInteract as any)._resume = setTimeout(startAuto, 6000);
  }

  prevBtn.addEventListener("click", () => { goTo(current - 1); onUserInteract(); });
  nextBtn.addEventListener("click", () => { goTo(current + 1); onUserInteract(); });
  dots.forEach((d) => d.addEventListener("click", () => { goTo(Number(d.dataset.index)); onUserInteract(); }));

  // Touch / drag swipe
  let startX = 0;
  track.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; stopAuto(); }, { passive: true });
  track.addEventListener("touchend", (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    setTimeout(startAuto, 6000);
  });

  // Mouse drag
  let mouseStartX = 0;
  let isDragging = false;
  track.addEventListener("mousedown", (e) => { mouseStartX = e.clientX; isDragging = true; stopAuto(); });
  track.addEventListener("mouseup", (e) => {
    if (!isDragging) return;
    isDragging = false;
    const diff = mouseStartX - e.clientX;
    if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    setTimeout(startAuto, 6000);
  });
  track.addEventListener("mouseleave", () => { isDragging = false; });

  // Pause while the carousel is hovered (desktop)
  const carousel = document.getElementById("cs-carousel") as HTMLElement;
  carousel.addEventListener("mouseenter", stopAuto);
  carousel.addEventListener("mouseleave", startAuto);

  // Pause when tab/window is hidden to avoid drift
  document.addEventListener("visibilitychange", () => {
    document.hidden ? stopAuto() : startAuto();
  });

  // Initial state
  prevBtn.disabled = false;
  startAuto();
</script>
