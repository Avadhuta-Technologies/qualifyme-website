---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import { caseStudies } from "../data/case-studies";

const csAccentMetric: Record<string, string> = {
  indigo: "text-indigo-600 dark:text-indigo-400",
  violet: "text-violet-600 dark:text-violet-400",
  cyan: "text-cyan-600 dark:text-cyan-400",
  emerald: "text-emerald-600 dark:text-emerald-400",
};
// Carousel accent maps
const csAccentGradient: Record<string, string> = {
  indigo: "bg-gradient-to-br from-indigo-700 via-indigo-800 to-violet-900",
  violet: "bg-gradient-to-br from-violet-700 via-violet-800 to-purple-900",
  cyan: "bg-gradient-to-br from-slate-700 via-slate-800 to-cyan-900",
  emerald: "bg-gradient-to-br from-slate-700 via-slate-800 to-emerald-900",
};
const csAccentGlow: Record<string, string> = {
  indigo: "bg-indigo-400",
  violet: "bg-violet-400",
  cyan: "bg-cyan-400",
  emerald: "bg-emerald-400",
};
const csAccentCheckBg: Record<string, string> = {
  indigo: "bg-indigo-50 dark:bg-indigo-900/40",
  violet: "bg-violet-50 dark:bg-violet-900/40",
  cyan: "bg-cyan-50 dark:bg-cyan-900/40",
  emerald: "bg-emerald-50 dark:bg-emerald-900/40",
};
const csAccentCheckIcon: Record<string, string> = {
  indigo: "text-indigo-600 dark:text-indigo-400",
  violet: "text-violet-600 dark:text-violet-400",
  cyan: "text-cyan-600 dark:text-cyan-400",
  emerald: "text-emerald-600 dark:text-emerald-400",
};
const csAccentCta: Record<string, string> = {
  indigo: "bg-indigo-600 hover:bg-indigo-500 text-white shadow-indigo-500/25",
  violet: "bg-violet-600 hover:bg-violet-500 text-white shadow-violet-500/25",
  cyan: "bg-cyan-600 hover:bg-cyan-500 text-white shadow-cyan-500/25",
  emerald: "bg-emerald-600 hover:bg-emerald-500 text-white shadow-emerald-500/25",
};

const logos = [
  "SoftTech Engineers Limited", "VNurt Solutions", "East Ocyon Bio", "Pazl Software Solutions",
  "Rubick AI", "Trovex AI", "Avadhuta Technologies",
];
---

<Layout
  title="QualifyMe — See How Candidates Actually Think"
  description="Go beyond screening. QualifyMe's AI-powered assessments and cognitive simulations reveal how candidates actually make decisions. Get started free."
  keywords="AI hiring, cognitive simulations, candidate assessment, recruitment automation, hiring platform"
  ogImage="/images/qualifyme-scores.avif"
>
  <main>

    {/* ════════════════════════════════════════════════════════════════════════
        HERO — dark gradient section with dot-grid texture
    ════════════════════════════════════════════════════════════════════════ */}
    <section
      id="home"
      class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-gradient-to-br from-indigo-700 via-indigo-800 to-violet-900 dark:from-slate-950 dark:via-indigo-950 dark:to-slate-900"
    >
      {/* Dot grid texture */}
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-60"></div>

      {/* Radial glow blobs */}
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute -top-32 -left-32 w-[600px] h-[600px] rounded-full bg-indigo-600/20 blur-[120px]"></div>
        <div class="absolute top-1/2 -right-24 w-[500px] h-[500px] rounded-full bg-violet-600/15 blur-[100px]"></div>
        <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] rounded-full bg-cyan-500/10 blur-[100px]"></div>
      </div>

      <Container>
        <div class="relative z-10 pt-28 pb-10 lg:pt-32 lg:pb-12">

          {/* Centered copy block */}
          <div class="max-w-4xl mx-auto text-center">
            <h1 class="font-bold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.08] text-white mb-6 reveal">
              Stop guessing from resumes.<br />
              <span class="text-gradient">See candidates perform.</span>
            </h1>

            <p class="text-lg sm:text-xl text-indigo-100 dark:text-slate-300 leading-relaxed mb-4 max-w-2xl mx-auto reveal reveal-delay-1">
              QualifyMe is an AI-powered screening platform that evaluates real skills at scale and introduces
              <strong class="text-white font-semibold">real-world job simulations</strong> to identify top performers before you hire.
            </p>

            <p class="text-sm text-indigo-200/70 dark:text-slate-400 mb-10 italic reveal reveal-delay-1">
              Screening is live today. Simulations are launching soon.
            </p>

            <div class="flex flex-wrap justify-center gap-4 mb-12 reveal reveal-delay-2">
              <a
                href="https://console.qualifyme.ai/sign-up"
                class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-white text-indigo-700 hover:bg-indigo-50 dark:bg-indigo-600 dark:text-white dark:hover:bg-indigo-500 px-7 text-base font-semibold shadow-lg shadow-black/20 dark:shadow-indigo-500/30 transition-all duration-200 hover:-translate-y-0.5"
              >
                Get Started Free
                <span class="iconify w-4 h-4" data-icon="uil:arrow-right" aria-hidden="true"></span>
              </a>
              <a
                href="/book-demo"
                class="inline-flex h-12 items-center justify-center rounded-full border border-white/30 bg-white/10 hover:bg-white/20 px-7 text-base font-semibold text-white transition-all duration-200 backdrop-blur-sm"
              >
                Book a Demo
              </a>
            </div>

            {/* Trust stats */}
            <div class="flex flex-wrap justify-center gap-10 reveal reveal-delay-3">
              {[
                { num: "2,400+", label: "assessments delivered" },
                { num: "70%", label: "faster time-to-shortlist" },
                { num: "100%", label: "audit-ready scoring" },
              ].map((s) => (
                <div class="text-center">
                  <p class="text-2xl font-bold text-white">{s.num}</p>
                  <p class="text-xs text-indigo-200/80 dark:text-slate-400 mt-0.5">{s.label}</p>
                </div>
              ))}
            </div>
          </div>

          {/* Full-width product screenshot */}
          <div class="mt-16 relative reveal reveal-delay-2">
            <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-indigo-500/20 to-violet-500/10 blur-3xl scale-105"></div>
            <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50 max-w-5xl mx-auto">
              <img
                src="/images/console-1.png"
                alt="QualifyMe hiring dashboard"
                class="w-full h-auto block"
              />
              {/* Floating badge */}
              <div class="absolute bottom-4 left-4 flex items-center gap-3 bg-white/10 backdrop-blur-md border border-white/20 rounded-xl px-4 py-2.5">
                <span class="h-2.5 w-2.5 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
                <div>
                  <p class="text-xs font-semibold text-white">AI Screening</p>
                  <p class="text-xs text-white/60">Live · 3 candidates evaluated</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </Container>

      {/* Bottom fade into next section */}
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-gray-950 to-transparent pointer-events-none hidden dark:block"></div>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        LOGO MARQUEE
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-white dark:bg-gray-950 py-10 border-b border-gray-100 dark:border-gray-800">
      <Container>
        <p class="text-center text-xs font-semibold uppercase tracking-widest text-gray-400 mb-8">
          Trusted by growing teams across fintech, SaaS, and enterprise hiring
        </p>
      </Container>
      <div class="marquee-track overflow-hidden">
        <div class="animate-marquee gap-16 items-center">
          {[...logos, ...logos].map((name) => (
            <div class="flex-shrink-0 px-8">
              <span class="text-gray-300 dark:text-gray-600 font-semibold text-lg tracking-wide select-none">
                {name}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        PROBLEM — light section, 3 problem cards
    ════════════════════════════════════════════════════════════════════════ */}
    <section id="problem" class="bg-white dark:bg-gray-950 py-24 lg:py-32">
      <Container>
        <div class="max-w-3xl mx-auto text-center mb-16 reveal">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-4">The Problem</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight">
            Hiring decisions are based<br class="hidden sm:block" /> on weak signals.
          </h2>
          <p class="mt-5 text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
            Resumes are optimized. Interviews are rehearsed. Tests measure what candidates memorized — not how they perform.
          </p>
          <p class="mt-3 text-lg text-gray-700 dark:text-gray-200 font-medium">
            You end up hiring the best <em class="not-italic text-primary">candidate</em>, not the best <em class="not-italic text-primary">employee</em>.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {[
            {
              icon: "uil:file-alt",
              color: "red",
              title: "Resumes show claims",
              body: "Not capability. Anyone can craft a strong profile.",
            },
            {
              icon: "uil:comment-alt",
              color: "orange",
              title: "Interviews reward confidence",
              body: "Not competence. Communication ≠ execution.",
            },
            {
              icon: "uil:clipboard-alt",
              color: "yellow",
              title: "Tests measure recall",
              body: "Not judgment. Scores don't reflect real decisions.",
            },
          ].map((card, i) => (
            <div
              class={`reveal reveal-delay-${i + 1} group relative rounded-2xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300`}
            >
              {/* Coloured top bar */}
              <div class={`absolute top-0 left-0 right-0 h-0.5 rounded-t-2xl ${card.color === "red" ? "bg-red-400" : card.color === "orange" ? "bg-orange-400" : "bg-yellow-400"}`}></div>
              <span class={`inline-flex w-11 h-11 rounded-xl items-center justify-center mb-5 ${card.color === "red" ? "bg-red-50 dark:bg-red-900/20 text-red-500" : card.color === "orange" ? "bg-orange-50 dark:bg-orange-900/20 text-orange-500" : "bg-yellow-50 dark:bg-yellow-900/20 text-yellow-500"}`}>
                <span class="iconify w-5 h-5" data-icon={card.icon} aria-hidden="true"></span>
              </span>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">{card.title}</h3>
              <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed">{card.body}</p>
            </div>
          ))}
        </div>

      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        TRANSITION — problem → solution bridge
    ════════════════════════════════════════════════════════════════════════ */}
    <div class="relative bg-indigo-600 dark:bg-indigo-700 py-14 overflow-hidden reveal">
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-20"></div>
      <div aria-hidden="true" class="absolute -left-24 top-1/2 -translate-y-1/2 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
      <div aria-hidden="true" class="absolute -right-24 top-1/2 -translate-y-1/2 w-72 h-72 bg-violet-500/20 rounded-full blur-3xl pointer-events-none"></div>
      <Container>
        <div class="relative text-center">
          <p class="text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-snug">
            You need to see how someone actually works —
            <span class="block mt-1 text-indigo-200">before you hire them.</span>
          </p>
          <div class="mt-6 flex items-center justify-center gap-2 text-indigo-200/70 text-sm font-medium">
            <span class="h-px w-12 bg-indigo-300/40"></span>
            <span>That's exactly what QualifyMe does</span>
            <span class="h-px w-12 bg-indigo-300/40"></span>
          </div>
        </div>
      </Container>
    </div>

    {/* ════════════════════════════════════════════════════════════════════════
        COMPARISON — subtle grey background
    ════════════════════════════════════════════════════════════════════════ */}
    <section id="comparison" class="bg-gray-50 dark:bg-gray-900 py-24 lg:py-32">
      <Container>
        <div class="max-w-3xl mx-auto text-center mb-14 reveal">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-4">The Solution</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight">
            From screening candidates<br class="hidden sm:block" /> to evaluating performance
          </h2>
          <p class="mt-5 text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
            QualifyMe helps you identify top candidates quickly with AI-powered screening — and go deeper with real-world job simulations when decisions matter most.
          </p>
        </div>

        <div class="max-w-3xl mx-auto reveal reveal-delay-1">
          <div class="rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-100 dark:bg-gray-800/80 border-b border-gray-200 dark:border-gray-700">
                  <th class="py-4 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Method</th>
                  <th class="py-4 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Limitation</th>
                  <th class="py-4 px-6 text-xs font-semibold text-gray-500 uppercase tracking-wider">Signal</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">
                {[
                  { method: "Resume", limit: "Can be inflated", dots: 1 },
                  { method: "Interview", limit: "Biased by confidence", dots: 2 },
                  { method: "MCQs / Coding tests", limit: "Low predictive validity", dots: 3 },
                ].map((row) => (
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                    <td class="py-4 px-6 font-medium text-gray-700 dark:text-gray-300 text-sm">{row.method}</td>
                    <td class="py-4 px-6 text-gray-500 dark:text-gray-400 text-sm hidden sm:table-cell">{row.limit}</td>
                    <td class="py-4 px-6">
                      <div class="flex gap-1.5">
                        {[1,2,3,4,5].map((n) => (
                          <span class={`w-3 h-3 rounded-full ${n <= row.dots ? "bg-primary" : "bg-gray-200 dark:bg-gray-700"}`}></span>
                        ))}
                      </div>
                    </td>
                  </tr>
                ))}
                <tr class="bg-indigo-50 dark:bg-indigo-950/40">
                  <td class="py-5 px-6 font-bold text-gray-900 dark:text-white text-sm">
                    <div class="flex items-center gap-2.5">
                      Cognitive Simulations
                      <span class="bg-primary text-white text-[10px] font-bold px-2 py-0.5 rounded-full">QualifyMe</span>
                    </div>
                    <p class="text-xs text-gray-500 dark:text-gray-400 font-normal mt-0.5">Decision-making under pressure</p>
                  </td>
                  <td class="py-5 px-6 text-gray-400 dark:text-gray-600 text-sm hidden sm:table-cell">—</td>
                  <td class="py-5 px-6">
                    <div class="flex gap-1.5">
                      {[1,2,3,4,5].map(() => (
                        <span class="w-3 h-3 rounded-full bg-primary"></span>
                      ))}
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-center mt-8 text-gray-600 dark:text-gray-400">
            QualifyMe gives you both — fast screening for volume, and cognitive simulations for the decisions that matter.
          </p>
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        PLATFORM OVERVIEW — white, two feature cards
    ════════════════════════════════════════════════════════════════════════ */}
    <section id="platform" class="bg-white dark:bg-gray-950 py-24 lg:py-32">
      <Container>
        <div class="max-w-3xl mx-auto text-center mb-14 reveal">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-4">One Platform · Two Layers</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight">
            Start fast.<br class="hidden sm:block" /> Go deep when it matters.
          </h2>
          <p class="mt-5 text-lg text-gray-500 dark:text-gray-400">
            Use AI screening to filter at speed. Add simulations when you need to see how someone actually thinks.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">

          {/* AI Screening */}
          <div class="reveal reveal-delay-1 group relative rounded-3xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8 md:p-10 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="absolute top-0 right-0 w-64 h-64 bg-green-400/5 rounded-full blur-3xl pointer-events-none"></div>
            <div class="relative">
              <div class="flex items-center justify-between mb-7">
                <div class="flex items-center gap-2 rounded-full bg-green-100 dark:bg-green-900/30 border border-green-200 dark:border-green-800 px-3 py-1">
                  <span class="h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  <span class="text-xs font-semibold text-green-700 dark:text-green-400">Live now</span>
                </div>
                <span class="iconify text-gray-300 dark:text-gray-700 w-10 h-10" data-icon="uil:bolt-alt" aria-hidden="true"></span>
              </div>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">AI Screening</h3>
              <p class="text-gray-500 dark:text-gray-400 text-base mb-7 leading-relaxed">
                Auto-generated assessments, AI evaluation, and instant candidate ranking — fully automated from invite to shortlist.
              </p>
              <ul class="space-y-3 mb-8">
                {[
                  "Auto-generated MCQs, coding challenges, and video Q&A",
                  "AI evaluates every response  instant scoring and ranking",
                  "Custom multi-round workflows per role",
                  "Branded candidate portal",
                ].map((item) => (
                  <li class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-300">
                    <span class="flex-shrink-0 mt-0.5 w-4 h-4 rounded-full bg-green-100 dark:bg-green-900/40 flex items-center justify-center">
                      <span class="iconify text-green-600 dark:text-green-400 w-2.5 h-2.5" data-icon="uil:check" aria-hidden="true"></span>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-7 pb-7 border-b border-gray-200 dark:border-gray-800">
                <strong class="text-gray-600 dark:text-gray-300">Best for:</strong> High-volume roles, technical validation, initial filtering
              </p>
              <a
                href="https://console.qualifyme.ai/sign-up"
                class="inline-flex h-11 items-center gap-2 rounded-full bg-primary hover:bg-indigo-500 px-6 text-sm font-semibold text-white transition-colors shadow-sm shadow-indigo-500/25"
              >
                Get Started Free
                <span class="iconify w-4 h-4" data-icon="uil:arrow-right" aria-hidden="true"></span>
              </a>
            </div>
          </div>

          {/* Cognitive Simulations */}
          <div class="reveal reveal-delay-2 group relative rounded-3xl border-2 border-indigo-200 dark:border-indigo-800/50 bg-gradient-to-br from-indigo-50 via-white to-violet-50 dark:from-indigo-950/40 dark:via-gray-900 dark:to-violet-950/20 p-8 md:p-10 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="absolute top-0 right-0 w-72 h-72 bg-indigo-400/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="relative">
              <div class="flex items-center justify-between mb-7">
                <div class="flex items-center gap-2 rounded-full bg-indigo-100 dark:bg-indigo-900/40 border border-indigo-200 dark:border-indigo-700 px-3 py-1">
                  <span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
                  <span class="text-xs font-semibold text-indigo-700 dark:text-indigo-300">Early access</span>
                </div>
                <span class="iconify text-indigo-200 dark:text-indigo-800 w-10 h-10" data-icon="uil:brain" aria-hidden="true"></span>
              </div>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">Real-world Job Simulation</h3>
              <p class="text-gray-500 dark:text-gray-400 text-base mb-7 leading-relaxed">
                Scenario-based simulations that respond to every decision — revealing judgment, adaptability, and performance under pressure.
              </p>
              <ul class="space-y-3 mb-8">
                {[
                  "Realistic work scenarios matched to your role",
                  "Every decision has consequences — simulation responds like real work",
                  "Adaptive difficulty that reveals how candidates handle escalation",
                  "Structured hiring recommendation with full audit trail",
                ].map((item) => (
                  <li class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-300">
                    <span class="flex-shrink-0 mt-0.5 w-4 h-4 rounded-full bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center">
                      <span class="iconify text-indigo-600 dark:text-indigo-400 w-2.5 h-2.5" data-icon="uil:check" aria-hidden="true"></span>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-7 pb-7 border-b border-indigo-100 dark:border-indigo-900/40">
                <strong class="text-gray-600 dark:text-gray-300">Best for:</strong> Senior hires, leadership roles, high-stakes decisions
              </p>
              <a
                href="/contact"
                class="inline-flex h-11 items-center gap-2 rounded-full border-2 border-indigo-500 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-950/40 px-6 text-sm font-semibold transition-colors"
              >
                Join Early Access →
              </a>
            </div>
          </div>
        </div>

        <p class="text-center mt-8 text-sm text-gray-400 dark:text-gray-600">
          Use one platform across the entire hiring funnel — from first screen to final decision.
        </p>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        SIMULATIONS DEEP DIVE — dark section for contrast
    ════════════════════════════════════════════════════════════════════════ */}
    <section id="simulations" class="relative bg-gray-50 dark:bg-slate-950 py-24 lg:py-32 overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-40"></div>
      <div aria-hidden="true" class="absolute top-0 right-0 w-[600px] h-[600px] bg-indigo-600/10 rounded-full blur-[120px] pointer-events-none"></div>
      <div aria-hidden="true" class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-violet-600/10 rounded-full blur-[100px] pointer-events-none"></div>

      <Container>
        <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start relative z-10">

          {/* Left — steps */}
          <div>
            <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-6 reveal">How Simulations Work</span>
