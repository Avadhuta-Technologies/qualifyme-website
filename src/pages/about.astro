---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
---

<Layout
  title="About QualifyMe — Hiring Based on Performance"
  description="QualifyMe is building a new way to evaluate talent — one that shows how people actually think, decide, and perform in real work situations."
  keywords="about QualifyMe, AI hiring platform, performance-based hiring, talent evaluation, hiring intelligence"
>
  <main>

    {/* ════════════════════════════════════════════════════════════════════════
        HERO
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="relative pt-32 pb-24 lg:pt-44 lg:pb-32 overflow-hidden bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 dark:from-gray-950 dark:via-indigo-950 dark:to-gray-950">
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-30"></div>
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute -top-32 left-1/3 w-[600px] h-[600px] rounded-full bg-indigo-700/15 blur-[140px]"></div>
        <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] rounded-full bg-violet-700/10 blur-[100px]"></div>
      </div>

      <Container>
        <div class="relative z-10 max-w-3xl mx-auto text-center">
          <div class="flex items-center justify-center gap-2 mb-6 reveal">
            <span class="h-1.5 w-1.5 rounded-full bg-indigo-400"></span>
            <span class="text-xs font-bold uppercase tracking-widest text-indigo-300">About QualifyMe</span>
          </div>
          <h1 class="font-bold text-4xl sm:text-5xl lg:text-6xl leading-[1.08] text-white mb-6 reveal reveal-delay-1">
            Hiring should be based on<br />
            <span class="text-gradient">performance</span>
          </h1>
          <p class="text-lg text-indigo-100/80 leading-relaxed max-w-2xl mx-auto reveal reveal-delay-2">
            We're building a new way to evaluate talent — one that shows how people actually think, decide, and perform in real work situations.
          </p>
        </div>
      </Container>

      <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-gray-950 to-transparent pointer-events-none hidden dark:block"></div>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        OUR BELIEF
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-white dark:bg-gray-950 py-24 lg:py-32">
      <Container>
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="reveal">
            <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">Our Belief</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-6">
              The hiring system is broken at its core.
            </h2>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
              For decades, hiring decisions have relied on indirect signals:
            </p>
            <ul class="space-y-4 mb-8">
              {[
                "Resumes that reflect how well someone presents themselves",
                "Interviews that reward confidence and storytelling",
                "Tests that measure recall, not real-world judgment",
              ].map((item) => (
                <li class="flex items-start gap-3 text-gray-600 dark:text-gray-300">
                  <span class="flex-shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-red-400"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
              These methods don't answer the most important question:
            </p>
            <p class="text-lg font-semibold text-gray-900 dark:text-white border-l-4 border-indigo-400 pl-4">
              Can this person actually do the job?
            </p>
          </div>

          <div class="reveal reveal-delay-1">
            <div class="rounded-3xl bg-indigo-50 dark:bg-indigo-950/30 border border-indigo-100 dark:border-indigo-900/50 p-10 text-center">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-100 dark:bg-indigo-900/50 mb-6">
                <span class="iconify w-8 h-8 text-indigo-600 dark:text-indigo-400" data-icon="uil:chart-growth" aria-hidden="true"></span>
              </div>
              <p class="text-lg font-semibold text-indigo-800 dark:text-indigo-200 leading-relaxed">
                We believe hiring should be grounded in <strong>observable performance</strong>, not proxies.
              </p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        WHAT WE'RE BUILDING
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-gray-50 dark:bg-gray-900 border-y border-gray-100 dark:border-gray-800 py-24 lg:py-32">
      <Container>
        <div class="max-w-2xl mx-auto text-center mb-16 reveal">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">What We're Building</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
            A platform to evaluate real performance
          </h2>
          <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
            QualifyMe is an AI-powered hiring platform designed to move beyond traditional screening.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto reveal reveal-delay-1">
          {/* Today */}
          <div class="rounded-2xl border border-emerald-100 dark:border-emerald-900/40 bg-white dark:bg-gray-950 p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/50 flex items-center justify-center">
                <span class="iconify w-4 h-4 text-emerald-600 dark:text-emerald-400" data-icon="uil:check-circle" aria-hidden="true"></span>
              </div>
              <div>
                <span class="text-xs font-bold uppercase tracking-widest text-emerald-500">Today</span>
                <p class="text-sm font-semibold text-gray-900 dark:text-white">Available now</p>
              </div>
            </div>
            <ul class="space-y-3">
              {[
                "Screen candidates at scale using AI-driven evaluations",
                "Eliminate manual resume filtering",
                "Identify high-potential candidates faster",
              ].map((item) => (
                <li class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-300">
                  <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          {/* Next */}
          <div class="rounded-2xl border border-indigo-100 dark:border-indigo-900/40 bg-white dark:bg-gray-950 p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center">
                <span class="iconify w-4 h-4 text-indigo-600 dark:text-indigo-400" data-icon="uil:rocket" aria-hidden="true"></span>
              </div>
              <div>
                <span class="text-xs font-bold uppercase tracking-widest text-indigo-500">Next</span>
                <p class="text-sm font-semibold text-gray-900 dark:text-white">Coming soon</p>
              </div>
            </div>
            <ul class="space-y-3">
              {[
                "Real-world job simulations that replicate how work actually happens",
                "Decision-based assessments where candidates navigate realistic scenarios",
                "Structured insights into how candidates think under pressure",
              ].map((item) => (
                <li class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-300">
                  <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        {/* Positioning line */}
        <div class="mt-12 text-center reveal reveal-delay-2">
          <div class="inline-flex items-center gap-4 rounded-full bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-700 px-8 py-4 shadow-sm">
            <span class="text-sm text-gray-500 dark:text-gray-400">From</span>
            <span class="text-sm font-semibold text-gray-900 dark:text-white">screening candidates</span>
            <svg class="w-5 h-5 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-sm font-semibold text-indigo-600 dark:text-indigo-400">understanding performance</span>
          </div>
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        WHY THIS MATTERS
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-white dark:bg-gray-950 py-24 lg:py-32">
      <Container>
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="reveal">
            <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">Why This Matters</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-6">
              Better hiring decisions change everything.
            </h2>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
              Hiring the right person is one of the highest-leverage decisions a company makes.
            </p>
            <div class="space-y-4 mb-8">
              <div class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                <p class="text-gray-600 dark:text-gray-300">Strong hires accelerate teams</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-red-400"></span>
                <p class="text-gray-600 dark:text-gray-300">Weak hires create hidden costs — time, morale, and execution risk</p>
              </div>
            </div>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
              Yet most hiring systems are still built on incomplete signals. We're solving this by giving teams a clearer, more reliable view of candidate capability — before they hire.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4 reveal reveal-delay-1">
            {[
              { value: "90%+", label: "reduction in unqualified candidates reaching interviews" },
              { value: "4×", label: "faster time to a shortlist your team can act on" },
              { value: "0", label: "manual resume reviews needed with AI screening" },
              { value: "100%", label: "of scores are traceable and audit-ready" },
            ].map((stat) => (
              <div class="rounded-2xl bg-indigo-50 dark:bg-indigo-950/30 border border-indigo-100 dark:border-indigo-900/50 p-6 text-center">
                <p class="text-3xl font-black text-indigo-600 dark:text-indigo-400 mb-2">{stat.value}</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 leading-snug">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        OUR APPROACH — 3 PRINCIPLES
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-gray-50 dark:bg-gray-900 border-y border-gray-100 dark:border-gray-800 py-24 lg:py-32">
      <Container>
        <div class="max-w-2xl mx-auto text-center mb-16 reveal">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">Our Approach</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight">
            Built on three principles
          </h2>
        </div>

        <div class="grid gap-6 md:grid-cols-3 max-w-5xl mx-auto reveal reveal-delay-1">
          {[
            {
              num: "01",
              title: "Measure what actually matters",
              body: "We focus on how candidates think, decide, and act — not just what they know.",
              color: "indigo",
              icon: "uil:focus-target",
            },
            {
              num: "02",
              title: "Remove bias and inconsistency",
              body: "Every candidate is evaluated using structured, reproducible systems — not subjective judgment.",
              color: "violet",
              icon: "uil:balance-scale",
            },
            {
              num: "03",
              title: "Combine speed with depth",
              body: "Start with fast AI screening. Go deeper with simulations when decisions are critical.",
              color: "cyan",
              icon: "uil:layers-alt",
            },
          ].map((p) => (
            <div class={`relative rounded-2xl border p-8 bg-white dark:bg-gray-950 overflow-hidden ${
              p.color === "indigo"
                ? "border-indigo-100 dark:border-indigo-900/50"
                : p.color === "violet"
                ? "border-violet-100 dark:border-violet-900/50"
                : "border-cyan-100 dark:border-cyan-900/50"
            }`}>
              <div class={`absolute top-0 left-0 right-0 h-1 ${
                p.color === "indigo" ? "bg-indigo-500" : p.color === "violet" ? "bg-violet-500" : "bg-cyan-500"
              }`}></div>
              <span class={`text-5xl font-black leading-none mb-5 block ${
                p.color === "indigo"
                  ? "text-indigo-100 dark:text-indigo-950"
                  : p.color === "violet"
                  ? "text-violet-100 dark:text-violet-950"
                  : "text-cyan-100 dark:text-cyan-950"
              }`}>{p.num}</span>
              <div class={`inline-flex items-center justify-center w-10 h-10 rounded-xl mb-4 ${
                p.color === "indigo"
                  ? "bg-indigo-100 dark:bg-indigo-900/50"
                  : p.color === "violet"
                  ? "bg-violet-100 dark:bg-violet-900/50"
                  : "bg-cyan-100 dark:bg-cyan-900/50"
              }`}>
                <span class={`iconify w-5 h-5 ${
                  p.color === "indigo"
                    ? "text-indigo-600 dark:text-indigo-400"
                    : p.color === "violet"
                    ? "text-violet-600 dark:text-violet-400"
                    : "text-cyan-600 dark:text-cyan-400"
                }`} data-icon={p.icon} aria-hidden="true"></span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">{p.title}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        WHO WE SERVE
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-white dark:bg-gray-950 py-24 lg:py-32">
      <Container>
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
          <div class="reveal">
            <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">Who We Serve</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-6">
              Designed for modern hiring teams
            </h2>
            <div class="space-y-4">
              {[
                {
                  icon: "uil:rocket",
                  label: "Startups",
                  desc: "Scaling their teams quickly without sacrificing candidate quality.",
                },
                {
                  icon: "uil:building",
                  label: "Mid-sized companies",
                  desc: "Hiring across multiple roles and needing a consistent evaluation standard.",
                },
                {
                  icon: "uil:office-building",
                  label: "Enterprises",
                  desc: "Looking to standardize and measurably improve hiring quality at scale.",
                },
              ].map((s) => (
                <div class="flex items-start gap-4 p-5 rounded-xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
                  <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center">
                    <span class="iconify w-5 h-5 text-indigo-600 dark:text-indigo-400" data-icon={s.icon} aria-hidden="true"></span>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900 dark:text-white">{s.label}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">{s.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="reveal reveal-delay-1">
            <p class="text-xs font-bold uppercase tracking-widest text-indigo-500 mb-6">Across roles like</p>
            <div class="flex flex-wrap gap-3">
              {[
                "Engineering",
                "Product",
                "Sales",
                "Data",
                "Design",
                "Leadership",
                "Operations",
                "Customer Success",
              ].map((role) => (
                <span class="inline-block rounded-full border border-indigo-100 dark:border-indigo-900/50 bg-indigo-50 dark:bg-indigo-950/30 text-indigo-700 dark:text-indigo-300 text-sm font-medium px-4 py-1.5">
                  {role}
                </span>
              ))}
            </div>

            {/* Company snapshot */}
            <div class="mt-10 rounded-2xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-7">
              <p class="text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-5">At a glance</p>
              <ul class="space-y-3">
                {[
                  { icon: "uil:map-marker", text: "Founded in India" },
                  { icon: "uil:bolt-alt", text: "AI-first hiring platform" },
                  { icon: "uil:briefcase", text: "Serving teams across SaaS, fintech, and enterprise" },
                  { icon: "uil:chart-bar", text: "Focused on high-signal, performance-based evaluation" },
                ].map((item) => (
                  <li class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300">
                    <span class="iconify w-4 h-4 text-indigo-500 flex-shrink-0" data-icon={item.icon} aria-hidden="true"></span>
                    {item.text}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        OUR VISION
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-indigo-600 dark:bg-indigo-700 py-24 lg:py-32 overflow-hidden relative">
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-20"></div>
      <Container>
        <div class="relative z-10 max-w-3xl mx-auto text-center reveal">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-300 mb-5">Our Vision</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-4">
            A world where hiring decisions are predictable
          </h2>
          <p class="text-indigo-100 leading-relaxed mb-12">
            We envision a future where every hiring decision is grounded in demonstrated ability, not assumption.
          </p>
          <div class="grid sm:grid-cols-3 gap-4 text-left">
            {[
              {
                heading: "Demonstrated ability",
                body: "Hiring is based on what candidates can do — observed in context, not assumed from a résumé.",
              },
              {
                heading: "Fair and consistent",
                body: "Every candidate is evaluated against the same bar, with no bias from who reviewed their application.",
              },
              {
                heading: "Predictable performance",
                body: "Teams can predict how someone will perform before making the hire — not hope for the best.",
              },
            ].map((v) => (
              <div class="rounded-2xl bg-white/10 border border-white/15 p-6 backdrop-blur-sm">
                <h3 class="font-bold text-white mb-2">{v.heading}</h3>
                <p class="text-sm text-indigo-100 leading-relaxed">{v.body}</p>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        BUILDING THE FUTURE
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="bg-white dark:bg-gray-950 py-24 lg:py-32">
      <Container>
        <div class="max-w-3xl mx-auto reveal">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-indigo-500 mb-4">Building the Future</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-6">
            We're just getting started.
          </h2>
          <div class="space-y-5 text-gray-500 dark:text-gray-400 leading-relaxed">
            <p>Screening is only the first step.</p>
            <p>
              The real opportunity is redefining how the world evaluates talent — moving from static assessments to dynamic, real-world performance.
            </p>
            <p class="text-gray-700 dark:text-gray-200 font-medium text-lg border-l-4 border-indigo-400 pl-5">
              That's what we're building.
            </p>
          </div>
        </div>
      </Container>
    </section>

    {/* ════════════════════════════════════════════════════════════════════════
        CTA
    ════════════════════════════════════════════════════════════════════════ */}
    <section class="relative bg-gradient-to-br from-indigo-600 via-indigo-700 to-violet-700 py-20 overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-20"></div>
      <Container>
        <div class="relative z-10 text-center max-w-2xl mx-auto reveal">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            See how better hiring works
          </h2>
          <p class="text-indigo-200 mb-8 text-lg leading-relaxed">
            Start screening today. Explore simulations as they launch.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="https://console.qualifyme.ai/sign-up"
              class="inline-flex h-12 items-center gap-2 rounded-full bg-white text-indigo-700 hover:bg-indigo-50 px-7 font-semibold text-sm transition-colors shadow-xl shadow-black/20"
            >
              Get Started Free
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href="/book-demo"
              class="inline-flex h-12 items-center rounded-full border border-white/30 bg-white/10 hover:bg-white/20 px-7 font-semibold text-sm text-white transition-colors backdrop-blur-sm"
            >
              Book a Demo
            </a>
          </div>
        </div>
      </Container>
    </section>

  </main>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
