---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import { ChevronRight, TrendingUp } from "@lucide/astro";
---

<Layout
  title="Pre Interview Job Fit Analysis & Technical Assessments | QualifyMe"
  description="Run a pre-interview job fit analysis by uploading a job description and resume. Identify skill gaps before moving to structured technical assessments with QualifyMe."
  keywords="pre-interview job fit analysis, technical hiring assessment, resume screening software, candidate skill evaluation, hiring assessment, job fit analysis tool"
  ogImage="/images/qualifyme-scores.avif"
>
  <main class="space-y-40 mb-40">
    {/* Hero Section */}
    <section id="hero" class="relative">
      <div
        aria-hidden="true"
        class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-40 dark:opacity-20"
      >
        <div
          class="blur-[106px] h-56 bg-gradient-to-br from-primary to-purple-400 dark:from-blue-700"
        >
        </div>
        <div
          class="blur-[106px] h-32 bg-gradient-to-r from-cyan-400 to-sky-300 dark:to-indigo-600"
        >
        </div>
      </div>
      <Container>
        <div class="relative pt-32 md:pt-40 lg:pt-48 text-center mx-auto">
          {/* Layer Indicator Badge */}
          <!-- <div class="inline-flex items-center justify-center mb-8">
            <div class="px-4 py-2 bg-black dark:bg-gray-800 text-white text-xs md:text-sm font-semibold tracking-wide uppercase rounded-sm">
              Layer 1: Screening | Layer 2: Assessments
            </div>
          </div> -->

          {/* Hero Headline */}
          <h1 class="text-gray-900 text-balance dark:text-white font-bold text-5xl md:text-6xl xl:text-7xl max-w-5xl mx-auto">
            Validate Skills with
            <span class="text-primary dark:text-blue-400"> Precision.</span>
          </h1>

          {/* Hero Subheadline */}
          <p class="mt-8 text-gray-700 dark:text-gray-300 text-lg md:text-xl max-w-3xl mx-auto leading-relaxed">
            From instant pre-interview screening to deep technical simulations. QualifyMe is the structured hiring platform for modern teams.
          </p>

          {/* CTA Buttons */}
          <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a
              href="https://console.qualifyme.ai/profile-screening"
              onclick="gtag('event', 'cta_hero_primary_click', { 'event_category': 'engagement', 'event_label': 'Run Pre-Interview Check' });"
              class="relative flex h-12 w-full sm:w-auto items-center justify-center px-8 before:absolute before:inset-0 before:rounded-sm before:bg-black dark:before:bg-white before:transition before:duration-300 hover:before:scale-105 active:duration-75 active:before:scale-95"
            >
              <span class="relative text-base font-semibold text-white dark:text-black flex items-center gap-2">
                Run Pre-Interview Check <ChevronRight size={18} />
              </span>
            </a>
            <a
              href="https://qualifyme.ai"
              onclick="gtag('event', 'cta_hero_secondary_click', { 'event_category': 'engagement', 'event_label': 'Explore Assessments' });"
              class="relative flex h-12 w-full sm:w-auto items-center justify-center px-8 before:absolute before:inset-0 before:rounded-sm before:border before:border-gray-300 dark:before:border-gray-600 before:bg-gray-100 dark:before:bg-gray-800 before:transition before:duration-300 hover:before:scale-105 active:duration-75 active:before:scale-95"
            >
              <span class="relative text-base font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
                Explore QualifyMe Assessments <ChevronRight size={18} />
              </span>
            </a>
          </div>

          {/* Trust Microcopy */}
          <p class="mt-6 text-sm text-gray-500 dark:text-gray-400">
            No account required | 30-second analysis | No credit-card required
          </p>

          {/* Hero Stats */}
          <div class="mt-16 grid grid-cols-3 gap-6 max-w-2xl mx-auto">
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">10+</div>
              <p class="text-xs md:text-sm text-gray-600 dark:text-gray-400 mt-2">Companies Hiring</p>
            </div>
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">98.2%</div>
              <p class="text-xs md:text-sm text-gray-600 dark:text-gray-400 mt-2">Accuracy Rate</p>
            </div>
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">30s</div>
              <p class="text-xs md:text-sm text-gray-600 dark:text-gray-400 mt-2">Quick Analysis</p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    {/* Layer 1: Pre-Interview Check Section */}
    <section id="layer1" class="relative py-20 md:py-32">
      <Container>
        <div class="grid lg:grid-cols-2 gap-12 items-stretch">
          {/* Left Column: Content */}
          <div class="space-y-8 flex flex-col h-full">
            <div>
              <p class="text-primary dark:text-blue-400 text-sm font-semibold uppercase tracking-wider mb-4">
                Intelligence Layer 01
              </p>
              <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
                Layer 1: The Pre-Interview Check
              </h2>
              <p class="text-lg text-gray-700 dark:text-gray-300">
                Identify signals and risks in 30 seconds before moving to deep validation.
              </p>
            </div>

            {/* Feature 1: Directional Screening */}
            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-950/30 dark:to-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-6">
              <div class="flex items-start gap-4 mb-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/20 dark:bg-blue-900/40 flex items-center justify-center">
                  <span class="text-lg font-bold text-primary dark:text-blue-400">1</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">
                    Directional Screening
                  </h3>
                  <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed">
                    The Pre-Interview Check provides the first signal—detecting CV discrepancies and risk flags instantly using our trained AI engine.
                  </p>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4 pt-5 border-t border-blue-200 dark:border-blue-800">
                <div class="space-y-2">
                  <p class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider">Score</p>
                  <div class="flex items-baseline gap-2">
                    <span class="text-3xl font-bold text-green-600 dark:text-green-400">72</span>
                    <span class="text-sm text-gray-600 dark:text-gray-400">/100</span>
                  </div>
                </div>
                <div class="space-y-2">
                  <p class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider">Signals</p>
                  <div class="flex items-center gap-2">
                    <div class="flex gap-1">
                      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300 text-xs font-bold">!</span>
                      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300 text-xs font-bold">!</span>
                    </div>
                    <span class="text-sm text-gray-600 dark:text-gray-400">2 Flags</span>
                  </div>
                </div>
              </div>
            </div>

            {/* Feature 2: Verified Competency */}
            <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-950/30 dark:to-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-6 opacity-30 dark:opacity-30 backdrop-blur-2xl">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-green-200 dark:bg-green-900/40 flex items-center justify-center">
                  <span class="text-lg font-bold text-green-700 dark:text-green-400">2</span>
                </div>
                <div class="flex-1">
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">
                    Verified Competency
                  </h3>
                  <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed mb-4">
                    Move to Layer 2 for deep technical simulations and role-specific assessments.
                  </p>

                  <div class="bg-white dark:bg-gray-800 rounded-lg p-3 border border-green-200 dark:border-green-800">
                    <p class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-2">Next Steps:</p>
                    <ul class="space-y-1 text-xs text-gray-600 dark:text-gray-400">
                      <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>System Design Assessment</span>
                      </li>
                      <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Role-Specific Simulations</span>
                      </li>
                      <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Competency Validation</span>
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* Right Column: Slider Animation */}
          <div class="space-y-4 flex flex-col h-full">
            <p class="text-sm text-gray-600 dark:text-gray-400 uppercase tracking-wider font-semibold">
              From raw resume data to structured hiring intelligence.
            </p>

            <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden p-5 h-full flex flex-col" style="cursor: col-resize;">
              <div class="relative w-full flex-1 min-h-[700px]">
                {/* Divider with gradient glow */}
                <div
                  id="slider"
                  class="absolute top-0 bottom-0 w-px z-40 bg-gradient-to-b from-transparent from-[2%] to-[95%] via-indigo-500 to-transparent"
                  style="left: 2%; top: 0px; z-index: 40;"
                  role="slider"
                  aria-label="Resume transformation slider"
                  aria-valuenow="2"
                  aria-valuemin="0"
                  aria-valuemax="100"
                >
                  {/* Glow halo - wide */}
                  <div class="w-36 h-full [mask-image:radial-gradient(100px_at_left,white,transparent)] absolute top-1/2 -translate-y-1/2 left-0 bg-gradient-to-r from-indigo-400 via-transparent to-transparent z-20 opacity-50"></div>

                  {/* Glow halo - narrow */}
                  <div class="w-10 h-1/2 [mask-image:radial-gradient(50px_at_left,white,transparent)] absolute top-1/2 -translate-y-1/2 left-0 bg-gradient-to-r from-cyan-400 via-transparent to-transparent z-10 opacity-100"></div>

                  {/* Handle - small square with dots */}
                  <div class="h-5 w-5 rounded-md top-1/2 -translate-y-1/2 bg-white z-30 -right-2.5 absolute flex items-center justify-center shadow-[0px_-1px_0px_0px_#FFFFFF40]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-black">
                      <circle cx="12" cy="12" r="1"></circle>
                      <circle cx="12" cy="5" r="1"></circle>
                      <circle cx="12" cy="19" r="1"></circle>
                    </svg>
                  </div>
                </div>

                {/* Left panel: Raw Resume (clipped) */}
                <div class="absolute inset-0 z-20 pointer-events-none rounded-xl overflow-hidden select-none" id="leftPanel" style="clip-path: inset(0px 80% 0px 0px);">
                  <div class="w-full h-full bg-white dark:bg-gray-900 p-5 rounded-lg flex flex-col justify-start overflow-y-auto">
                    <div class="space-y-2.5 text-sm">
                      {/* Contact Info */}
                      <div>
                        <h3 class="text-base font-bold text-gray-900 dark:text-white">Arjun Mehta</h3>
                        <p class="text-xs text-gray-600 dark:text-gray-400">Senior Front-end Architect</p>
                        <p class="text-[11px] text-gray-500 dark:text-gray-500">arjun.mehta@example.com | +91-98765-43210</p>
                        <p class="text-[11px] text-gray-500 dark:text-gray-500">Bengaluru, India | linkedin.com/in/arjun-mehta</p>
                      </div>

                      {/* Professional Summary */}
                      <div>
                        <h4 class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">PROFESSIONAL SUMMARY</h4>
                        <p class="text-[11px] text-gray-700 dark:text-gray-400 leading-snug">
                          Innovative Full-Stack Developer with 10+ years designing scalable systems using event-driven architecture, microservices, and domain-driven design patterns. Proven track record of leading teams and delivering high-impact solutions.
                        </p>
                      </div>

                      {/* Experience */}
                      <div>
                        <h4 class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">EXPERIENCE</h4>
                        <div class="space-y-2">
                          <div>
                            <p class="text-xs font-medium text-gray-900 dark:text-white">Senior Front-end Architect</p>
                            <p class="text-[11px] text-gray-600 dark:text-gray-400">TechNova Solutions | 2019 - Present</p>
                            <p class="text-[11px] text-gray-600 dark:text-gray-400">Designed microservices architecture, improved scalability by 40%, led team of 12 engineers. Architected real-time data streaming pipelines using Kafka with sub-second event processing.</p>
                          </div>
                          <div>
                            <p class="text-xs font-medium text-gray-900 dark:text-white">Front-end Architect</p>
                            <p class="text-[11px] text-gray-600 dark:text-gray-400">CloudSphere Technologies | 2015 - 2019</p>
                            <p class="text-[11px] text-gray-600 dark:text-gray-400">Built resilient systems with 99.99% uptime, data processing workflows using Databricks DLT for analytics. Developed APIs with contract-first design.</p>
                          </div>
                          <div>
                            <p class="text-xs font-medium text-gray-900 dark:text-white">Software Engineer</p>
                            <p class="text-[11px] text-gray-600 dark:text-gray-400">NextGen Systems | 2012 - 2015</p>
                            <p class="text-[11px] text-gray-600 dark:text-gray-400">Developed backend services in Java and Python. Designed REST APIs and integrated with NoSQL databases.</p>
                          </div>
                        </div>
                      </div>

                      {/* Core Competencies */}
                      <div>
                        <h4 class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">CORE COMPETENCIES</h4>
                        <p class="text-[11px] text-gray-700 dark:text-gray-400 leading-snug">
                          Microservices • Cloud Platforms • Kafka • Docker & Kubernetes • System Design • Team Leadership
                        </p>
                      </div>

                      {/* Education */}
                      <div>
                        <h4 class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">EDUCATION</h4>
                        <p class="text-xs font-medium text-gray-900 dark:text-white">B.Tech Computer Science</p>
                        <p class="text-[11px] text-gray-600 dark:text-gray-400">IIT Delhi | 2008 - 2012</p>
                      </div>

                      {/* Technical Skills */}
                      <div>
                        <h4 class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">TECHNICAL SKILLS</h4>
                        <p class="text-[11px] text-gray-700 dark:text-gray-400 leading-snug">
                          Java • Python • AWS • Azure • Kafka • Docker • Kubernetes • MongoDB • Cassandra
                        </p>
                      </div>

                      {/* Certifications */}
                      <div>
                        <h4 class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">CERTIFICATIONS</h4>
                        <p class="text-[11px] text-gray-700 dark:text-gray-400">AWS Solutions Architect • Azure Architect Expert • CKA • Databricks Certified</p>
                      </div>

                      {/* Key Achievements */}
                      <div>
                        <h4 class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">KEY ACHIEVEMENTS</h4>
                        <ul class="text-[11px] text-gray-700 dark:text-gray-400 space-y-1 leading-snug">
                          <li>• 40% scalability improvement</li>
                          <li>• Mentored 12+ engineers</li>
                          <li>• 30% deployment cycle reduction</li>
                          <li>• 99.99% uptime systems</li>
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Right panel: QualifyMe Report Card (full behind clip) */}
                <div class="absolute top-0 left-0 z-[19] rounded-xl w-full h-full select-none overflow-hidden">
                  <div class="w-full h-full bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-950/40 dark:to-indigo-950/40 p-4 rounded-lg flex flex-col justify-start overflow-y-auto">
                    {/* Header */}
                    <div class="mb-2">
                      <h3 class="text-base font-bold text-gray-900 dark:text-white">Arjun Mehta</h3>
                      <p class="text-xs text-gray-600 dark:text-gray-400">Senior Front-end Architect | 10+ Yrs | IIT Delhi</p>
                      <p class="text-[10px] text-gray-500 dark:text-gray-500">GENERATED 24 FEB 2026 • Analysis ID: QM-2026-0247</p>
                    </div>

                    {/* Score Circle & Recommendation */}
                    <div class="flex items-start gap-2.5 mb-2 pb-2 border-b border-blue-200 dark:border-blue-800">
                      <div class="flex-shrink-0">
                        <div class="w-14 h-14 rounded-full bg-white dark:bg-gray-800 flex items-center justify-center border-3 border-green-500 shadow-sm">
                          <div class="text-center">
                            <div class="text-lg font-bold text-green-600">72</div>
                            <div class="text-[7px] text-gray-600 dark:text-gray-400 font-semibold">FIT SCORE</div>
                          </div>
                        </div>
                      </div>

                      <div class="flex-1 space-y-1">
                        <div class="bg-white dark:bg-gray-800 rounded px-1.5 py-0.5 inline-block">
                          <p class="text-[9px] font-bold text-green-600 dark:text-green-400 uppercase tracking-wide">✓ HIGHLY RECOMMENDED</p>
                        </div>
                        <p class="text-[10px] text-gray-700 dark:text-gray-300 leading-snug">
                          Exceptional architectural background with proven expertise in building distributed systems at scale. Demonstrated team leadership and mentorship capabilities.
                        </p>
                      </div>
                    </div>

                    {/* Risk Assessment */}
                    <div class="mb-2 pb-2 border-b border-blue-200 dark:border-blue-800">
                      <p class="text-[9px] font-bold text-gray-800 dark:text-gray-200 uppercase mb-1">Risk Assessment</p>
                      <div class="space-y-1 text-[10px]">
                        <div class="flex items-center gap-1">
                          <span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>
                          <span class="text-gray-700 dark:text-gray-300">No CV discrepancies detected</span>
                        </div>
                        <div class="flex items-center gap-1">
                          <span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>
                          <span class="text-gray-700 dark:text-gray-300">Consistent career progression</span>
                        </div>
                        <div class="flex items-center gap-1">
                          <span class="inline-block w-2 h-2 rounded-full bg-yellow-500"></span>
                          <span class="text-gray-700 dark:text-gray-300">Minor: Industry exposure gaps</span>
                        </div>
                      </div>
                    </div>

                    {/* Key Strengths */}
                    <div class="mb-2 pb-2 border-b border-blue-200 dark:border-blue-800">
                      <p class="text-[9px] font-bold text-gray-800 dark:text-gray-200 uppercase mb-1">Key Strengths</p>
                      <div class="flex flex-wrap gap-1">
                        <span class="px-1.5 py-0.5 bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 rounded text-[8px] font-semibold">Microservices</span>
                        <span class="px-1.5 py-0.5 bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 rounded text-[8px] font-semibold">Cloud Arch</span>
                        <span class="px-1.5 py-0.5 bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 rounded text-[8px] font-semibold">Team Lead</span>
                        <span class="px-1.5 py-0.5 bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 rounded text-[8px] font-semibold">Kafka/Streaming</span>
                        <span class="px-1.5 py-0.5 bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 rounded text-[8px] font-semibold">DDD Pattern</span>
                      </div>
                    </div>

                    {/* Recommended Assessments */}
                    <div class="mb-2 pb-2 border-b border-blue-200 dark:border-blue-800">
                      <p class="text-[9px] font-bold text-gray-800 dark:text-gray-200 uppercase mb-1">Validate These Skills</p>
                      <div class="flex flex-wrap gap-1">
                        <span class="px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 rounded text-[8px] font-semibold">Kubernetes</span>
                        <span class="px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 rounded text-[8px] font-semibold">System Design</span>
                        <span class="px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 rounded text-[8px] font-semibold">AWS/Azure</span>
                        <span class="px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 rounded text-[8px] font-semibold">Leadership</span>
                      </div>
                    </div>

                    {/* Job Requirement Coverage */}
                    <div class="mb-2 pb-2 border-b border-blue-200 dark:border-blue-800">
                      <p class="text-[9px] font-bold text-gray-800 dark:text-gray-200 uppercase mb-1">Job Requirement Match</p>
                      <div class="space-y-1 text-[10px]">
                        <div class="flex items-center justify-between">
                          <span class="text-gray-700 dark:text-gray-300 flex-1">Microservices Architecture</span>
                          <div class="flex items-center gap-0.5">
                            <div class="w-1.5 h-1.5 bg-green-500 rounded-full"></div>
                            <span class="text-green-600 dark:text-green-400 font-semibold">Strong</span>
                          </div>
                        </div>
                        <div class="flex items-center justify-between">
                          <span class="text-gray-700 dark:text-gray-300 flex-1">Cloud Platforms (AWS/Azure)</span>
                          <div class="flex items-center gap-0.5">
                            <div class="w-1.5 h-1.5 bg-green-500 rounded-full"></div>
                            <span class="text-green-600 dark:text-green-400 font-semibold">Strong</span>
                          </div>
                        </div>
                        <div class="flex items-center justify-between">
                          <span class="text-gray-700 dark:text-gray-300 flex-1">Team Leadership & Mentoring</span>
                          <div class="flex items-center gap-0.5">
                            <div class="w-1.5 h-1.5 bg-green-500 rounded-full"></div>
                            <span class="text-green-600 dark:text-green-400 font-semibold">Strong</span>
                          </div>
                        </div>
