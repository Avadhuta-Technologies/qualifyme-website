<script>
  // Slider interaction for transformation animation (Cutshort pattern)
  const slider = document.getElementById("slider");
  const leftPanel = document.getElementById("leftPanel");
  const container = slider?.parentElement;

  let isActive = false;
  let isAnimating = true;
  let containerRect: DOMRect;
  let currentPosition = 25; // Starting position (left side to show raw resume)
  let animationId: number;

  const setPosition = (percentage: number) => {
    currentPosition = Math.max(0, Math.min(percentage, 100));
    slider!.style.left = `${currentPosition}%`;
    leftPanel!.style.clipPath = `inset(0px ${100 - currentPosition}% 0px 0px)`;
    slider!.setAttribute("aria-valuenow", Math.round(currentPosition).toString());
  };

  const animate = () => {
    if (isActive) {
      // Stop animation when user is dragging
      animationId = requestAnimationFrame(animate);
      return;
    }

    if (isAnimating) {
      // Oscillate between 5% and 95% over 8 seconds
      const now = Date.now();
      const elapsed = (now % 8000) / 8000; // 8 second cycle

      // Use sine wave for smooth oscillation
      const position = 50 + Math.sin(elapsed * Math.PI * 2) * 45;
      setPosition(position);
    }

    animationId = requestAnimationFrame(animate);
  };

  if (slider && leftPanel && container) {
    containerRect = container.getBoundingClientRect();

    const updatePosition = (clientX: number) => {
      const x = Math.max(0, Math.min(clientX - containerRect.left, containerRect.width));
      const percentage = (x / containerRect.width) * 100;
      setPosition(percentage);
    };

    const handleMouseDown = (e: MouseEvent) => {
      isActive = true;
      containerRect = container.getBoundingClientRect();
      document.body.style.userSelect = "none";
    };

    const handleTouchStart = (e: TouchEvent) => {
      isActive = true;
      containerRect = container.getBoundingClientRect();
      document.body.style.userSelect = "none";
    };

    const handleMouseMove = (e: MouseEvent) => {
      if (!isActive) return;
      updatePosition(e.clientX);
    };

    const handleTouchMove = (e: TouchEvent) => {
      if (!isActive) return;
      updatePosition(e.touches[0].clientX);
    };

    const handleEnd = () => {
      isActive = false;
      document.body.style.userSelect = "";
    };

    slider.addEventListener("mousedown", handleMouseDown);
    slider.addEventListener("touchstart", handleTouchStart);
    document.addEventListener("mousemove", handleMouseMove);
    document.addEventListener("touchmove", handleTouchMove);
    document.addEventListener("mouseup", handleEnd);
    document.addEventListener("touchend", handleEnd);

    // Start animation loop
    animate();
  }

  // Keyboard support for slider accessibility
  if (slider && leftPanel) {
    slider.addEventListener("keydown", (e: KeyboardEvent) => {
      const step = 2; // percentage

      if (e.key === "ArrowLeft") {
        e.preventDefault();
        isActive = true;
        setPosition(currentPosition - step);
        isActive = false;
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        isActive = true;
        setPosition(currentPosition + step);
        isActive = false;
      }
    });

    // Make slider focusable
    slider.setAttribute("tabindex", "0");
  }
</script>

<style>
