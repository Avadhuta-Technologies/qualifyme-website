---
import Layout from "../../../layouts/Layout.astro";
import Container from "../../../components/Container.astro";
import { caseStudies } from "../../../data/case-studies";
import type { CaseStudy } from "../../../data/case-studies";

export function getStaticPaths() {
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

const { cs } = Astro.props as { cs: CaseStudy };

// Accent colour palettes
const palette = {
  indigo: {
    heroBg: "from-indigo-700 via-indigo-800 to-violet-900 dark:from-slate-950 dark:via-indigo-950 dark:to-slate-900",
    badge: "bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300",
    sectionLabel: "text-indigo-600 dark:text-indigo-400",
    metricBg: "bg-indigo-50 dark:bg-indigo-950/40 border-indigo-100 dark:border-indigo-800",
    metricValue: "text-indigo-600 dark:text-indigo-400",
    dot: "bg-indigo-500",
    stepCircle: "bg-indigo-600 shadow-indigo-500/30",
    exampleBg: "bg-indigo-50 dark:bg-indigo-950/30 border-indigo-100 dark:border-indigo-800/60",
    exampleValue: "text-indigo-700 dark:text-indigo-300",
    ctaBg: "from-indigo-600 via-indigo-700 to-violet-700",
    iconBg: "bg-indigo-100 dark:bg-indigo-900/40",
    iconColor: "text-indigo-600 dark:text-indigo-400",
    checkBg: "bg-indigo-100 dark:bg-indigo-900/40",
    checkColor: "text-indigo-600 dark:text-indigo-400",
    bar: "bg-indigo-500",
  },
  violet: {
    heroBg: "from-violet-700 via-violet-800 to-purple-900 dark:from-slate-950 dark:via-violet-950 dark:to-slate-900",
    badge: "bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300",
    sectionLabel: "text-violet-600 dark:text-violet-400",
    metricBg: "bg-violet-50 dark:bg-violet-950/40 border-violet-100 dark:border-violet-800",
    metricValue: "text-violet-600 dark:text-violet-400",
    dot: "bg-violet-500",
    stepCircle: "bg-violet-600 shadow-violet-500/30",
    exampleBg: "bg-violet-50 dark:bg-violet-950/30 border-violet-100 dark:border-violet-800/60",
    exampleValue: "text-violet-700 dark:text-violet-300",
    ctaBg: "from-violet-600 via-violet-700 to-purple-700",
    iconBg: "bg-violet-100 dark:bg-violet-900/40",
    iconColor: "text-violet-600 dark:text-violet-400",
    checkBg: "bg-violet-100 dark:bg-violet-900/40",
    checkColor: "text-violet-600 dark:text-violet-400",
    bar: "bg-violet-500",
  },
  cyan: {
    heroBg: "from-cyan-700 via-cyan-800 to-teal-900 dark:from-slate-950 dark:via-cyan-950 dark:to-slate-900",
    badge: "bg-cyan-100 dark:bg-cyan-900/40 text-cyan-700 dark:text-cyan-300",
    sectionLabel: "text-cyan-600 dark:text-cyan-400",
    metricBg: "bg-cyan-50 dark:bg-cyan-950/40 border-cyan-100 dark:border-cyan-800",
    metricValue: "text-cyan-600 dark:text-cyan-400",
    dot: "bg-cyan-500",
    stepCircle: "bg-cyan-600 shadow-cyan-500/30",
    exampleBg: "bg-cyan-50 dark:bg-cyan-950/30 border-cyan-100 dark:border-cyan-800/60",
    exampleValue: "text-cyan-700 dark:text-cyan-300",
    ctaBg: "from-cyan-600 via-cyan-700 to-teal-700",
    iconBg: "bg-cyan-100 dark:bg-cyan-900/40",
    iconColor: "text-cyan-600 dark:text-cyan-400",
    checkBg: "bg-cyan-100 dark:bg-cyan-900/40",
    checkColor: "text-cyan-600 dark:text-cyan-400",
    bar: "bg-cyan-500",
  },
  emerald: {
    heroBg: "from-emerald-700 via-emerald-800 to-teal-900 dark:from-slate-950 dark:via-emerald-950 dark:to-slate-900",
    badge: "bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300",
    sectionLabel: "text-emerald-600 dark:text-emerald-400",
    metricBg: "bg-emerald-50 dark:bg-emerald-950/40 border-emerald-100 dark:border-emerald-800",
    metricValue: "text-emerald-600 dark:text-emerald-400",
    dot: "bg-emerald-500",
    stepCircle: "bg-emerald-600 shadow-emerald-500/30",
    exampleBg: "bg-emerald-50 dark:bg-emerald-950/30 border-emerald-100 dark:border-emerald-800/60",
    exampleValue: "text-emerald-700 dark:text-emerald-300",
    ctaBg: "from-emerald-600 via-emerald-700 to-teal-700",
    iconBg: "bg-emerald-100 dark:bg-emerald-900/40",
    iconColor: "text-emerald-600 dark:text-emerald-400",
    checkBg: "bg-emerald-100 dark:bg-emerald-900/40",
    checkColor: "text-emerald-600 dark:text-emerald-400",
    bar: "bg-emerald-500",
  },
};

const p = palette[cs.accentColor];
---

<Layout
  title={`${cs.company} Case Study — QualifyMe`}
  description={cs.summary}
  keywords={`${cs.company}, case study, QualifyMe, AI hiring, ${cs.industry}`}
>
  <main>

    {/* ── Hero ── */}
    <section class={`relative bg-gradient-to-br ${p.heroBg} pt-32 pb-20 overflow-hidden`}>
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-30"></div>
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-white/5 blur-[120px]"></div>
        <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-white/5 blur-[100px]"></div>
      </div>

      <Container>
        <div class="relative z-10">
          {/* Breadcrumb */}
          <nav class="flex items-center gap-2 text-xs text-white/50 mb-8 reveal">
            <a href="/" class="hover:text-white/80 transition-colors">Home</a>
            <span>/</span>
            <a href="/customers/case-studies" class="hover:text-white/80 transition-colors">Case Studies</a>
            <span>/</span>
            <span class="text-white/80">{cs.company}</span>
          </nav>

          <div class="max-w-4xl">
            <span class={`inline-block text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-5 reveal ${p.badge}`}>
              {cs.industry}
            </span>
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-5 reveal reveal-delay-1">
              {cs.company}
            </h1>
            <p class="text-xl sm:text-2xl text-white/70 font-medium mb-8 reveal reveal-delay-2">
              {cs.headline}
            </p>

            {/* Key metric chips */}
            <div class="flex flex-wrap gap-3 reveal reveal-delay-3">
              <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl px-4 py-2.5">
                <span class="text-2xl font-black text-white">{cs.keyMetric}</span>
                <span class="text-sm text-white/70">{cs.keyMetricLabel}</span>
              </div>
              {cs.teamSize && (
                <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl px-4 py-2.5">
                  <span class="text-sm text-white/80">{cs.teamSize}</span>
                </div>
              )}
            </div>
          </div>
        </div>
      </Container>

      <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-gray-950 to-transparent pointer-events-none hidden dark:block"></div>
    </section>

    {/* ── Key outcomes summary bar ── */}
    <section class="bg-white dark:bg-gray-950 py-10 border-b border-gray-100 dark:border-gray-800">
      <Container>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {cs.outcomes.slice(0, 4).map((outcome, i) => (
            <div class={`reveal reveal-delay-${i + 1} flex items-start gap-3`}>
              <span class={`flex-shrink-0 mt-0.5 w-5 h-5 rounded-full ${p.dot} flex items-center justify-center`}>
                <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <p class="text-sm text-gray-600 dark:text-gray-300 leading-snug">{outcome}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    {/* ── Body content ── */}
    <section class="bg-white dark:bg-gray-950 py-24 lg:py-32">
      <Container>
        <div class="max-w-3xl mx-auto space-y-20">

          {/* — Challenge — */}
          <div class="reveal">
            <span class={`text-xs font-bold uppercase tracking-widest ${p.sectionLabel} mb-3 block`}>The Challenge</span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">{cs.challenge.title}</h2>
            <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed mb-6">{cs.challenge.description}</p>
            <ul class="space-y-3">
              {cs.challenge.points.map((point) => (
                <li class="flex items-start gap-3">
                  <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-red-400"></span>
                  <span class="text-gray-600 dark:text-gray-300 text-base">{point}</span>
                </li>
              ))}
            </ul>
          </div>

          {/* Divider */}
          <div class="border-t border-gray-100 dark:border-gray-800"></div>

          {/* — Solution — */}
          <div class="reveal">
            <span class={`text-xs font-bold uppercase tracking-widest ${p.sectionLabel} mb-3 block`}>The Solution</span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">Screening with QualifyMe</h2>
            <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed mb-6">{cs.solution.description}</p>
            <div class="rounded-2xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-6 space-y-3">
              <p class="text-xs font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-4">What changed</p>
              {cs.solution.changes.map((change, i) => (
                <div class="flex items-start gap-4">
                  <span class={`flex-shrink-0 w-7 h-7 rounded-full ${p.stepCircle} shadow-lg text-white text-xs font-bold flex items-center justify-center`}>
                    {i + 1}
                  </span>
                  <p class="text-gray-700 dark:text-gray-200 text-base leading-relaxed pt-0.5">{change}</p>
                </div>
              ))}
            </div>
          </div>

          {/* Divider */}
          <div class="border-t border-gray-100 dark:border-gray-800"></div>

          {/* — Impact — */}
          <div class="reveal">
            <span class={`text-xs font-bold uppercase tracking-widest ${p.sectionLabel} mb-3 block`}>The Impact</span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">Drastic Reduction in Hiring Noise</h2>
            <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed mb-8">{cs.impact.description}</p>

            {cs.impact.example && (
              <div class={`rounded-2xl border p-6 ${p.exampleBg}`}>
                <p class={`text-sm font-bold mb-5 ${p.exampleValue}`}>{cs.impact.example.label}</p>
                <div class="grid sm:grid-cols-2 gap-4">
                  {cs.impact.example.items.map((item) => (
                    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-800 p-4">
                      <p class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-1">{item.label}</p>
                      <p class={`text-xl font-bold ${p.exampleValue}`}>{item.value}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>

          {/* Divider */}
          <div class="border-t border-gray-100 dark:border-gray-800"></div>

          {/* — Key Outcomes — */}
          <div class="reveal">
            <span class={`text-xs font-bold uppercase tracking-widest ${p.sectionLabel} mb-3 block`}>Key Outcomes</span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-6">Results at a glance</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {cs.outcomes.map((outcome) => (
                <div class="flex items-start gap-3 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-100 dark:border-gray-800 p-4">
                  <span class={`flex-shrink-0 mt-0.5 w-5 h-5 rounded-full ${p.checkBg} flex items-center justify-center`}>
                    <svg class={`w-3 h-3 ${p.checkColor}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                      <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span class="text-gray-700 dark:text-gray-200 text-sm leading-relaxed">{outcome}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Divider */}
          <div class="border-t border-gray-100 dark:border-gray-800"></div>

          {/* — Why it worked — */}
          <div class="reveal">
            <span class={`text-xs font-bold uppercase tracking-widest ${p.sectionLabel} mb-3 block`}>Why It Worked</span>
            <blockquote class="rounded-2xl bg-gray-50 dark:bg-gray-900 border-l-4 border-gray-300 dark:border-gray-700 pl-6 pr-6 py-6 text-gray-700 dark:text-gray-200 text-lg leading-relaxed italic">
              {cs.whyItWorked}
            </blockquote>
          </div>

          {/* Divider */}
          <div class="border-t border-gray-100 dark:border-gray-800"></div>

          {/* — Conclusion — */}
          <div class="reveal">
            <span class={`text-xs font-bold uppercase tracking-widest ${p.sectionLabel} mb-3 block`}>Conclusion</span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">What this means for your team</h2>
            <p class="text-gray-500 dark:text-gray-400 text-base leading-relaxed mb-5">{cs.conclusion.description}</p>
            <ul class="space-y-3">
              {cs.conclusion.points.map((point) => (
                <li class="flex items-start gap-3">
                  <span class={`flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full ${p.dot}`}></span>
                  <span class="text-gray-700 dark:text-gray-200 text-base">{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </Container>
    </section>

    {/* ── More case studies ── */}
    <section class="bg-gray-50 dark:bg-gray-900 py-20 border-t border-gray-100 dark:border-gray-800">
      <Container>
        <div class="text-center mb-10">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">More Customer Stories</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {caseStudies.filter((other) => other.slug !== cs.slug).slice(0, 3).map((other) => {
            const otherPalette = palette[other.accentColor];
            return (
              <a
                href={`/customers/case-studies/${other.slug}`}
                class="group relative rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 p-6 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 overflow-hidden"
              >
                <div class={`absolute top-0 left-0 right-0 h-0.5 ${otherPalette.bar}`}></div>
                <span class={`inline-block text-xs font-medium px-2.5 py-1 rounded-full mb-3 ${otherPalette.badge}`}>{other.industry}</span>
                <h3 class="font-bold text-gray-900 dark:text-white text-sm mb-1">{other.company}</h3>
                <p class="text-gray-400 dark:text-gray-500 text-xs leading-snug mb-4">{other.headline}</p>
                <div class="flex items-center gap-1 text-xs font-semibold text-gray-400 group-hover:text-gray-600 dark:group-hover:text-gray-200 transition-colors">
                  Read story
                  <svg class="w-3 h-3 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
        <div class="text-center mt-8">
          <a href="/customers/case-studies" class="text-sm font-semibold text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors">
            ← Back to all case studies
          </a>
        </div>
      </Container>
    </section>

    {/* ── CTA ── */}
    <section class={`relative bg-gradient-to-br ${p.ctaBg} py-20 overflow-hidden`}>
      <div aria-hidden="true" class="absolute inset-0 hero-dots opacity-20"></div>
      <Container>
        <div class="relative z-10 text-center max-w-xl mx-auto reveal">
          <h2 class="text-3xl font-bold text-white mb-4">See what QualifyMe can do for your team</h2>
          <p class="text-white/70 mb-8">Start screening smarter today — free to get started.</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="https://console.qualifyme.ai/sign-up"
              class="inline-flex h-11 items-center gap-2 rounded-full bg-white text-indigo-700 hover:bg-indigo-50 px-6 font-semibold text-sm transition-colors shadow-xl shadow-black/20"
            >
              Get Started Free
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href="/book-demo"
              class="inline-flex h-11 items-center rounded-full border border-white/30 bg-white/10 hover:bg-white/20 px-6 font-semibold text-sm text-white transition-colors backdrop-blur-sm"
            >
              Book a Demo
            </a>
          </div>
        </div>
      </Container>
    </section>

  </main>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
