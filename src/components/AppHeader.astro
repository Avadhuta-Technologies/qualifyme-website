---
import Container from "./Container.astro";

const navItems = [
  {
    label: "Product",
    submenu: [
      { to: "/product", label: "Overview" },
      { to: "/product/ai-screening", label: "AI Screening" },
      { to: "/product/simulations", label: "Cognitive Simulations" },
      { to: "/product/how-it-works", label: "How It Works" },
    ],
  },
  {
    label: "Solutions",
    submenu: [
      { to: "/solutions/use-cases", label: "Use Cases" },
      { to: "/solutions/roles", label: "By Role" },
      { to: "/solutions/hiring-stage", label: "By Hiring Stage" },
    ],
  },
  {
    label: "Customers",
    submenu: [
      { to: "/customers/case-studies", label: "Case Studies" },
      { to: "/customers/case-studies/avadhuta", label: "Avadhuta Technologies" },
      { to: "/customers/case-studies/rubick", label: "RubickAI" },
      { to: "/customers/case-studies/softtech", label: "SoftTech Engineers" },
      { to: "/customers/case-studies/vnurt", label: "VNurt Technology" },
    ],
  },
  { to: "/pricing", label: "Pricing" },
  { to: "/technology", label: "Technology" },
  {
    label: "Resources",
    submenu: [
      { to: "/resources/blog", label: "Blog" },
      { to: "/resources/guides", label: "Guides" },
      { to: "/resources/help", label: "Help Center" },
    ],
  },
  {
    label: "Company",
    submenu: [
      { to: "/about", label: "About" },
      { to: "/contact", label: "Contact" },
      { to: "/careers", label: "Careers" },
    ],
  },
];
---

<header>
  <nav id="nav" class="fixed top-0 left-0 right-0 z-50 w-full nav-bar">
    <Container>
      <div class="flex items-center justify-between h-16">

        {/* ── Logo ── */}
        <a href="/" aria-label="QualifyMe home" class="flex items-center gap-2.5 flex-shrink-0">
          <img src="/logo-dark.png"   alt="" class="h-7 w-auto block dark:hidden" />
          <img src="/logo_white.png"  alt="" class="h-7 w-auto hidden dark:block" />
          <span class="text-lg font-bold tracking-tight text-gray-700 dark:text-gray-200">QualifyMe</span>
        </a>

        {/* ── Desktop links ── */}
        <div class="hidden lg:flex items-center gap-1">
          {navItems.map((item) =>
            item.submenu ? (
              <div class="relative group/dd">
                <button
                  class="nav-item flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium"
                  aria-haspopup="true"
                >
                  {item.label}
                  <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover/dd:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>

                {/* Dropdown panel */}
                <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/dd:opacity-100 group-hover/dd:visible transition-all duration-200 z-50">
                  <div class="w-48 rounded-xl border nav-dropdown overflow-hidden shadow-xl">
                    {item.submenu.map((sub) => (
                      <a
                        href={sub.to}
                        class="nav-dropdown-item flex items-center gap-2.5 px-4 py-2.5 text-sm transition-colors"
                      >
                        <span class="w-1 h-1 rounded-full bg-indigo-400 opacity-0 group-hover:opacity-100 flex-shrink-0"></span>
                        {sub.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a href={item.to} class="nav-item px-3 py-2 rounded-lg text-sm font-medium">
                {item.label}
              </a>
            )
          )}
        </div>

        {/* ── Desktop CTAs ── */}
        <div class="hidden lg:flex items-center gap-2">
          <a
            href="/contact"
            class="nav-outline h-9 px-4 rounded-full text-sm font-semibold border transition-colors duration-200 flex items-center"
          >
            Book a Demo
          </a>
          <a
            href="https://console.qualifyme.ai"
            class="h-9 px-5 rounded-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold transition-colors duration-200 shadow-sm shadow-indigo-500/30 flex items-center gap-1.5"
          >
            Get Started
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        {/* ── Hamburger (mobile) ── */}
        <button
          id="hamburger"
          aria-label="Open menu"
          class="lg:hidden flex flex-col justify-center items-center w-9 h-9 rounded-lg nav-hamburger-btn gap-1.5"
        >
          <span id="ham-top"    class="ham-bar w-5 h-0.5 rounded-full transition-all duration-300"></span>
          <span id="ham-mid"    class="ham-bar w-5 h-0.5 rounded-full transition-all duration-300"></span>
          <span id="ham-bot"    class="ham-bar w-3.5 h-0.5 rounded-full transition-all duration-300 self-end"></span>
        </button>

      </div>
    </Container>

    {/* ── Mobile menu panel ── */}
    <div
      id="mobile-menu"
      class="lg:hidden overflow-hidden transition-all duration-300 ease-in-out"
      style="max-height: 0;"
    >
      <div class="nav-mobile-panel border-t">
        <Container>
          <div class="py-4 space-y-1">
            {navItems.map((item) =>
              item.submenu ? (
                <div class="mobile-group">
                  <p class="mobile-group-label px-3 pt-3 pb-1 text-xs font-semibold uppercase tracking-widest">
                    {item.label}
                  </p>
                  <div class="space-y-0.5">
                    {item.submenu.map((sub) => (
                      <a href={sub.to} class="mobile-link flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium">
                        <span class="w-1 h-1 rounded-full bg-indigo-400 flex-shrink-0"></span>
                        {sub.label}
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                <a href={item.to} class="mobile-link flex items-center px-3 py-2.5 rounded-lg text-sm font-semibold">
                  {item.label}
                </a>
              )
            )}
          </div>

          {/* Mobile CTAs */}
          <div class="pb-5 pt-3 border-t nav-mobile-cta-border flex flex-col gap-2.5">
            <a
              href="/contact"
              class="nav-outline flex items-center justify-center h-10 rounded-full border text-sm font-semibold transition-colors"
            >
              Book a Demo
            </a>
            <a
              href="https://console.qualifyme.ai"
              class="flex items-center justify-center gap-2 h-10 rounded-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold transition-colors shadow-sm shadow-indigo-500/20"
            >
              Get Started
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </Container>
      </div>
    </div>
  </nav>
</header>

<script>
  const hamburger = document.querySelector("#hamburger") as HTMLButtonElement;
  const mobileMenu = document.querySelector("#mobile-menu") as HTMLElement;
  const hamTop    = document.querySelector("#ham-top") as HTMLElement;
  const hamMid    = document.querySelector("#ham-mid") as HTMLElement;
  const hamBot    = document.querySelector("#ham-bot") as HTMLElement;
  let isOpen = false;

  // ── Mobile menu toggle ──
  function toggleMenu() {
    isOpen = !isOpen;
    if (isOpen) {
      mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";
      // Animate to X
      hamTop.style.transform = "translateY(7px) rotate(45deg)";
      hamMid.style.opacity = "0";
      hamBot.style.transform = "translateY(-7px) rotate(-45deg)";
      hamBot.style.width = "20px";
    } else {
      mobileMenu.style.maxHeight = "0";
      hamTop.style.transform = "";
      hamMid.style.opacity = "";
      hamBot.style.transform = "";
      hamBot.style.width = "";
    }
  }
  hamburger.addEventListener("click", toggleMenu);

  // Close on mobile link click
  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => { if (isOpen) toggleMenu(); });
  });
</script>
